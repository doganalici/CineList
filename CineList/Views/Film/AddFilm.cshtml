@model CineList.Models.Film
@{
    ViewData["Title"] = "Film Ekleme";
}

<div class="text-center mt-4">
    <h1><i class="bi bi-plus-circle text-warning"> FİLM EKLEME </i> <i class="bi bi-plus-circle text-warning"></i></h1>
</div>
<div class="col-md-6 mx-auto mt-4">
    <div class="card border-warning" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
        <div class="card-body p-4">
            @using (Html.BeginForm("AddFilm", "Film", FormMethod.Post, new { id = "filmForm" }))
            {
                <div class="input-group mb-3">
                    <span class="input-group-text">
                        <i class="bi bi-camera-reels"></i>
                    </span>
                    @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Film Adı" })
                </div>

                <div class="mb-3">
                    <label class="form-label text-white">Film Türü</label>
                    <div id="turSecim" class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Aksiyon">Aksiyon</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Komedi">Komedi</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Dram">Dram</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Korku">Korku</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Bilim Kurgu">Bilim Kurgu</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Animasyon">Animasyon</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Macera">Macera</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Gerilim">Gerilim</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Fantastik">Fantastik</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Polisiye">Polisiye</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Romantik">Romantik</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Belgesel">Belgesel</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Biyografi">Biyografi</button>
                        <button type="button" class="btn btn-outline-warning tur-btn" data-tur="Savaş">Savaş</button>
                    </div>
                    @Html.HiddenFor(m => m.Genre)
                </div>

                <div class="input-group mb-3">
                    <span class="input-group-text">
                        <i class="bi bi-person-video"></i>
                    </span>
                    @Html.TextBoxFor(m => m.Director, new { @class = "form-control", placeholder = "Film Yönetmeni" })
                </div>

                <div class="form-check mb-3">
                    @Html.CheckBoxFor(m => m.Status, new { @class = "form-check-input" })
                    <label class="form-check-label text-white">
                        <i class="bi bi-eye text-warning"></i> İzlendi
                    </label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="bi bi-plus-circle"></i> Film Ekle
                    </button>
                    <button type="button" class="btn btn-outline-light w-100" onclick="formuTemizle()">
                        <i class="bi bi-arrow-counterclockwise"></i> Temizle
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.tur-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            this.classList.toggle('btn-warning');
            this.classList.toggle('btn-outline-warning');

            const secilenTurler = [];
            document.querySelectorAll('.tur-btn.btn-warning').forEach(b => {
                secilenTurler.push(b.dataset.tur);
            });
            document.getElementById('Genre').value = secilenTurler.join(', ');
        });
    });

           function formuTemizle() {
        document.getElementById('filmForm').reset();
        document.querySelectorAll('.tur-btn').forEach(b => {
            b.classList.remove('btn-warning');
            b.classList.add('btn-outline-warning');
        });
        document.getElementById('Genre').value = '';
    }

</script>

<canvas id="bgCanvas" style="position:fixed; top:0; left:0; z-index:-1; width:100%; height:100%;"></canvas>

<script>
    const canvas = document.getElementById('bgCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    let mouse = { x: canvas.width / 2, y: canvas.height / 2 };

    const parcaciklar = [];
    const SAYI = 80;

    for (let i = 0; i < SAYI; i++) {
        parcaciklar.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            boyut: Math.random() * 2 + 1
        });
    }

    document.addEventListener('mousemove', function (e) {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
    });

    window.addEventListener('resize', function () {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });

    function ciz() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#0a0a0f';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        parcaciklar.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;

            if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
            if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

            // Mouse yakınındaki parçacıklar büyüsün
            const dx = mouse.x - p.x;
            const dy = mouse.y - p.y;
            const uzaklik = Math.sqrt(dx * dx + dy * dy);
            const buyukluk = uzaklik < 150 ? p.boyut * 3 : p.boyut;

            ctx.beginPath();
            ctx.arc(p.x, p.y, buyukluk, 0, Math.PI * 2);
            ctx.fillStyle = uzaklik < 150 ? 'rgba(255,193,7,0.9)' : 'rgba(255,193,7,0.4)';
            ctx.fill();
        });

        // Parçacıklar arası çizgiler
        parcaciklar.forEach((p, i) => {
            parcaciklar.slice(i + 1).forEach(q => {
                const dx = p.x - q.x;
                const dy = p.y - q.y;
                const uzaklik = Math.sqrt(dx * dx + dy * dy);

                if (uzaklik < 120) {
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(q.x, q.y);
                    ctx.strokeStyle = `rgba(255,193,7,${1 - uzaklik / 120})`;
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            });

            // Mouse ile yakın parçacıklar arasında elektrik çizgisi
            const dx = mouse.x - p.x;
            const dy = mouse.y - p.y;
            const uzaklik = Math.sqrt(dx * dx + dy * dy);

            if (uzaklik < 200) {
                ctx.beginPath();
                ctx.moveTo(p.x, p.y);
                ctx.lineTo(mouse.x, mouse.y);
                ctx.strokeStyle = `rgba(255,193,7,${1 - uzaklik / 200})`;
                ctx.lineWidth = 0.8;
                ctx.stroke();
            }
        });

        requestAnimationFrame(ciz);
    }

    ciz();
</script>