@model IEnumerable<CineList.Models.Film>

@{
    ViewData["Title"] = "Film Silme";
}


<div class="text-center mt-4">
    <h1><i class="bi bi-dash-circle text-warning"> FİLM SİLME </i> <i class="bi bi-dash-circle text-warning"></i></h1>
</div>

<table class="table table-dark table-striped mt-5">
    <thead>
        <tr>
            <th>Id</th>
            <th>Film Adı</th>
            <th>Türü</th>
            <th>Yönetmen</th>
            <th>Durum</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var film in Model)
        {
            <tr>
                <td>@film.Id</td>
                <td>@film.Name</td>
                <td>@film.Genre</td>
                <td>@film.Director</td>
                <td>
                    @if (film.Status)
                    {
                        <span class="badge bg-success fs-6">İzlendi</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark fs-6">İzlenmedi</span>
                    }
                </td>

                <td>
                    @using (Html.BeginForm("DeleteFilm", "Film", new { id = film.Id }, FormMethod.Post))
                    {
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('@film.Name filmini silmek istediğinize emin misiniz?')">
                            <i class="bi bi-trash"></i> Sil
                        </button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>



<canvas id="bgCanvas" style="position:fixed; top:0; left:0; z-index:-1; width:100%; height:100%;"></canvas>

<script>
    const canvas = document.getElementById('bgCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    let mouse = { x: canvas.width / 2, y: canvas.height / 2 };

    const parcaciklar = [];
    const SAYI = 80;

    for (let i = 0; i < SAYI; i++) {
        parcaciklar.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            boyut: Math.random() * 2 + 1
        });
    }

    document.addEventListener('mousemove', function (e) {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
    });

    window.addEventListener('resize', function () {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });

    function ciz() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#0a0a0f';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        parcaciklar.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;

            if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
            if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

            // Mouse yakınındaki parçacıklar büyüsün
            const dx = mouse.x - p.x;
            const dy = mouse.y - p.y;
            const uzaklik = Math.sqrt(dx * dx + dy * dy);
            const buyukluk = uzaklik < 150 ? p.boyut * 3 : p.boyut;

            ctx.beginPath();
            ctx.arc(p.x, p.y, buyukluk, 0, Math.PI * 2);
            ctx.fillStyle = uzaklik < 150 ? 'rgba(255,193,7,0.9)' : 'rgba(255,193,7,0.4)';
            ctx.fill();
        });

        // Parçacıklar arası çizgiler
        parcaciklar.forEach((p, i) => {
            parcaciklar.slice(i + 1).forEach(q => {
                const dx = p.x - q.x;
                const dy = p.y - q.y;
                const uzaklik = Math.sqrt(dx * dx + dy * dy);

                if (uzaklik < 120) {
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(q.x, q.y);
                    ctx.strokeStyle = `rgba(255,193,7,${1 - uzaklik / 120})`;
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            });

            // Mouse ile yakın parçacıklar arasında elektrik çizgisi
            const dx = mouse.x - p.x;
            const dy = mouse.y - p.y;
            const uzaklik = Math.sqrt(dx * dx + dy * dy);

            if (uzaklik < 200) {
                ctx.beginPath();
                ctx.moveTo(p.x, p.y);
                ctx.lineTo(mouse.x, mouse.y);
                ctx.strokeStyle = `rgba(255,193,7,${1 - uzaklik / 200})`;
                ctx.lineWidth = 0.8;
                ctx.stroke();
            }
        });

        requestAnimationFrame(ciz);
    }

    ciz();
</script>
