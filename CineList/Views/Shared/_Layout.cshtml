<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Film Takip Yönetim Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CineList.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
</head>
<body class="d-flex flex-column" style="min-height:90vh;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-secondary">
            <a class="navbar-brand m-1"><i class="bi bi-projector"></i> Film Yönetim Sistemi </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
                <div class="navbar-nav">
                    <a class="nav-item nav-link active" href="/Home/Index"> <i class="bi bi-house-door"></i> ANASAYFA </a>
                    <a class="nav-item nav-link active" href="/Film/Index"> <i class="bi bi-collection-play"> FİLM LİSTESİ </i></a>
                    <form class="form-inline my-2 my-lg-0">
                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle active" href="#" id="filmDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-camera-reels "></i> FİLM İŞLEMLERİ
                            </a>
                            <div class="dropdown-menu" aria-labelledby="filmDropdown">
                                <a class="dropdown-item" href="/Film/AddFilm"><i class="bi bi-plus-circle"></i> Film Ekle</a>
                                <a class="dropdown-item" href="/Film/UpdateFilm"><i class="bi bi-pencil"></i> Film Düzenle</a>
                                <a class="dropdown-item" href="/Film/DeleteFilm"><i class="bi bi-trash"></i> Film Sil</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <form class="form-inline my-2 my-lg-0">
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        <i class="bi bi-person-circle"> ÜYE GİRİŞİ</i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownMenuLink">
                        <a class="dropdown-item" href="/Home/SignIn"><i class="bi bi-key"> Giriş Yap</i></a>
                        <a class="dropdown-item" href="/Home/SignUp"><i class="bi bi-person-plus"> Üye Ol</i></a>
                    </div>
                </div>

            </form>
        </nav>
    </header>
    <div class="container-fluid px-0 flex-grow-1">
        <main role="main" style="min-height: calc(97vh - 115px);">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-secondary text-white py-3">
        <div class="container text-center">
            &copy; 2026 - Film Takip Yönetim Sistemi - Tüm Hakları Saklıdır
            <a asp-area="" asp-controller="Home" asp-action="Index" class="text-warning fw-bold"> Anasayfa</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
